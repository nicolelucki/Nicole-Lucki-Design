// ── MODAL ──
const modal=document.getElementById('modal'), modalBlur=document.getElementById('modalBlur'),
      cardFlipper=document.getElementById('cardFlipper'), flipBack=document.getElementById('flipBack');
let activeProject=null;

function openModal(p) {
    activeProject = p;
    renderModal(p);
    modal.classList.add('active');
    cardFlipper.style.animation='none';
    void cardFlipper.offsetWidth;
    cardFlipper.style.animation='flipIn .6s cubic-bezier(.23,1,.32,1) forwards';
}

function renderModal(p) {
    const L = currentLang;
    document.getElementById('modalNum').textContent   = p.num[L];
    document.getElementById('modalTitle').textContent = p.title[L];
    document.getElementById('modalDesc').textContent  = p.desc[L];
    document.getElementById('modalTags').innerHTML    = p.chips[L].map(c=>`<span class="modal-tag">${c}</span>`).join('');
    document.getElementById('modalCta').textContent   = L==='es' ? 'Ver proyecto →' : 'View project →';
    flipBack.className = 'flip-back '+p.modalScheme;
}

document.getElementById('modalClose').addEventListener('click', ()=>modal.classList.remove('active'));
modalBlur.addEventListener('click', ()=>modal.classList.remove('active'));
document.addEventListener('keydown', e=>{ if(e.key==='Escape') modal.classList.remove('active'); });

// ── RENDER CARDS ──
function t(p, key) { return (p[key] && typeof p[key]==='object') ? p[key][currentLang] : (p[key]||''); }

function cardHTML(p) {
    if (p.type==='horizontal') {
        const s=p.textScheme, img=p.cardImg
            ? `<img src="${p.cardImg}" alt="${t(p,'title')}" style="width:100%;height:100%;object-fit:cover;display:block;">`
            : `<div class="ch-img-ph" style="background:${p.placeholderBg}">${p.deco}</div>`;
        return `<div class="card card-${p.size} card-horizontal ${p.cardBg||''}">
            <div class="ch-img">${img}</div>
            <div class="ch-info">
                <div class="ch-tag ${s}">${t(p,'tag')}</div>
                <div class="ch-title ${s}">${t(p,'title')}</div>
                <div class="ch-sub ${s}">${t(p,'subtitle')}</div>
                <div class="ch-pill ${s}">${t(p,'pill')}</div>
            </div></div>`;
    }
    const bg=p.cardImg?`<img class="card-bg" src="${p.cardImg}" alt="${t(p,'title')}">`
        :`<div class="card-bg-div" style="background:${p.placeholderBg}">${p.deco}</div>`;
    return `<div class="card card-${p.size} ${p.color||'ca'}">
        ${bg}<div class="card-overlay"></div>
        <div class="card-inner">
            <div class="card-tag">${t(p,'tag')}</div>
            <div class="${p.size==='lg'?'card-title-lg':'card-title'}">${t(p,'title')}</div>
        </div></div>`;
}

const rowMap={rowA:[],rowB:[],rowC:[]};
data.forEach(p=>rowMap[p.row].push(p));

function renderAllRows() {
    ['rowA','rowB','rowC'].forEach(id=>{
        const el=document.getElementById(id), items=rowMap[id];
        el.innerHTML=[...items,...items,...items,...items].map(cardHTML).join('');
        el.querySelectorAll('.card').forEach((c,i)=>c.addEventListener('click',()=>openModal(items[i%items.length])));
    });
}
renderAllRows();
</script>
