<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Nicole Lucki | Portfolio - Proyectos</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Alice&family=Lora:wght@400;700&display=swap" rel="stylesheet">
<style>
* { margin:0; padding:0; box-sizing:border-box; }

:root {
    --dark-blue:#2f4153;
    --steel-blue:#587d8e;
    --light-blue:#a7c1d1;
    --beige:#ddd8d4;
    --white:#ffffff;
}

body { font-family:'Lora',serif; background:var(--dark-blue); color:var(--dark-blue); overflow-x:hidden; cursor:none; }

/* ── CURSOR ── */
.cursor { width:8px; height:8px; border-radius:50%; position:fixed; pointer-events:none; z-index:9999; transform:translate(-50%,-50%); transition:background .3s ease; }
.cursor-ring { width:36px; height:36px; border-radius:50%; border:1px solid transparent; position:fixed; pointer-events:none; z-index:9998; transform:translate(-50%,-50%); transition:width .2s,height .2s,border-color .3s ease; }
.cursor.dark       { background:var(--dark-blue); }
.cursor-ring.dark  { border-color:rgba(47,65,83,.45); }
.cursor.light      { background:var(--beige); }
.cursor-ring.light { border-color:rgba(221,216,212,.45); }
.cursor.menu       { background:var(--light-blue); }
.cursor-ring.menu  { border-color:rgba(167,193,209,.5); }
@media(max-width:768px){ body{cursor:auto;} .cursor,.cursor-ring{display:none;} }

::-webkit-scrollbar { width:8px; }
::-webkit-scrollbar-track { background:var(--light-blue); }
::-webkit-scrollbar-thumb { background:var(--steel-blue); border-radius:4px; }

/* ── HEADER ── */
.header {
    position:fixed; top:0; left:0; width:100%;
    padding:clamp(14px,1.8vh,24px) clamp(20px,3vw,40px);
    display:flex; justify-content:space-between; align-items:center;
    z-index:100;
    background:rgba(221,216,212,0.95);
    backdrop-filter:blur(10px);
    transition:background .3s ease, backdrop-filter .3s ease;
}
.header-left { display:flex; align-items:center; gap:clamp(12px,1.8vw,24px); height:100%; }
.header-right { display:flex; align-items:center; gap:clamp(10px,1.5vw,20px); }

/* ── LOGO ── */
.logo-svg { height:clamp(28.56px,2.856vw,40.8px); width:auto; display:block; position:absolute; left:50%; top:50%; transform:translate(-50%,-50%); }

/* ── HAMBURGUESA ── */
.menu-btn {
    width: clamp(24px,2.2vw,32px);
    display: flex;
    flex-direction: column;
    gap: 5px;
    cursor: none;
    z-index: 102;
    background: none;
    border: none;
    padding: 0;
}
.menu-btn span {
    display: block;
    width: 100%;
    height: 2px;
    background: var(--dark-blue);
    border-radius: 2px;
    transition: all .3s ease;
}
.menu-btn.active span:nth-child(1) { transform:rotate(45deg) translate(5px,5px); background:var(--light-blue); }
.menu-btn.active span:nth-child(2) { opacity:0; }
.menu-btn.active span:nth-child(3) { transform:rotate(-45deg) translate(5px,-5px); background:var(--light-blue); }

/* ── LANG TOGGLE ── */
.lang-toggle { display:flex; align-items:center; font-family:'Lora',serif; font-size:clamp(11px,.9vw,13px); color:var(--dark-blue); cursor:none; border:1px solid rgba(47,65,83,.25); border-radius:20px; padding:clamp(3px,.3vw,4px); background:rgba(221,216,212,.5); backdrop-filter:blur(4px); }
.lang-toggle span { opacity:.5; transition:all .3s; padding:clamp(3px,.3vw,4px) clamp(7px,.7vw,10px); border-radius:16px; color:var(--dark-blue); }
.lang-toggle span.active { opacity:1; font-weight:700; background:var(--dark-blue); color:var(--beige); }
.lang-divider { display:none; }

/* ── MENU OVERLAY ── */
.menu-overlay { position:fixed; top:0; left:0; width:100%; height:100vh; background:var(--dark-blue); z-index:99; display:flex; align-items:center; justify-content:center; opacity:0; pointer-events:none; transition:opacity .5s ease; }
.menu-overlay.active { opacity:1; pointer-events:all; }
.menu-nav { text-align:center; }
.menu-nav a { display:block; font-family:'Alice',serif; font-size:clamp(2rem,5.5vw,5rem); color:var(--beige); text-decoration:none; margin:clamp(10px,1.5vh,20px) 0; opacity:0; transform:translateY(30px); transition:all .5s ease; cursor:none; }
.menu-overlay.active .menu-nav a { opacity:1; transform:translateY(0); }
.menu-overlay.active .menu-nav a:nth-child(1) { transition-delay:.1s; }
.menu-overlay.active .menu-nav a:nth-child(2) { transition-delay:.2s; }
.menu-overlay.active .menu-nav a:nth-child(3) { transition-delay:.3s; }
.menu-overlay.active .menu-nav a:nth-child(4) { transition-delay:.4s; }
.menu-nav a:hover { color:var(--light-blue); }

/* ── SLIDER ── */
.slider-wrap { display:flex; flex-direction:column; gap:14px; overflow:hidden; padding:120px 0 60px; background:var(--dark-blue); min-height:100vh; }
.slider-row { display:flex; gap:14px; width:max-content; align-items:center; }
.row-a { animation:goLeft  22s linear infinite; }
.row-b { animation:goRight 26s linear infinite; }
.row-c { animation:goLeft  20s linear infinite; }
.slider-row:hover { animation-play-state:paused; }
@keyframes goLeft  { 0%{transform:translateX(0)}    100%{transform:translateX(-50%)} }
@keyframes goRight { 0%{transform:translateX(-50%)} 100%{transform:translateX(0)}    }

/* ── CARDS ── */
.card { border-radius:14px; overflow:hidden; flex-shrink:0; cursor:pointer; position:relative; transition:transform .25s,box-shadow .25s; }
.card:hover { transform:translateY(-6px); box-shadow:0 18px 44px rgba(0,0,0,.35); }
.card-sm { width:260px; height:190px; }
.card-lg { width:420px; height:260px; }
.card-bg { position:absolute; inset:0; width:100%; height:100%; object-fit:cover; display:block; }
.card-bg-div { position:absolute; inset:0; display:flex; align-items:center; justify-content:center; font-size:2.5rem; opacity:.25; }
.card-overlay { position:absolute; inset:0; background:linear-gradient(to top,rgba(47,65,83,.82) 0%,transparent 65%); }
.card-inner { position:absolute; inset:0; display:flex; flex-direction:column; justify-content:flex-end; padding:1rem 1.1rem; z-index:1; }
.card-tag { font-family:'Lora',serif; font-style:italic; font-size:.6rem; letter-spacing:.2em; text-transform:uppercase; color:#A7C1D1; margin-bottom:5px; }
.card-title    { font-family:'Lora',serif; font-size:.85rem; font-weight:500; color:#DDD8D4; line-height:1.35; }
.card-title-lg { font-family:'Lora',serif; font-size:1rem;   font-weight:500; color:#DDD8D4; line-height:1.35; }
.ca { background:#DDD8D4; } .cb { background:#A7C1D1; } .cc { background:#587D8E; }

.card-horizontal { display:flex; flex-direction:row; position:relative; overflow:hidden; }
.bg-light { background:#DDD8D4; } .bg-mid { background:#A7C1D1; }
.ch-img { width:52%; height:100%; flex-shrink:0; overflow:hidden; }
.ch-img img { width:100%; height:100%; object-fit:cover; display:block; }
.ch-img-ph { width:100%; height:100%; display:flex; align-items:center; justify-content:center; font-size:2.5rem; opacity:.3; }

.ch-info { flex:1; display:flex; flex-direction:column; justify-content:center; padding:20px 22px; gap:8px; }
.ch-tag { font-family:'Lora',serif; font-style:italic; font-size:.58rem; letter-spacing:.18em; text-transform:uppercase; }
.ch-tag.dark { color:#587D8E; } .ch-tag.light { color:#2F4153; opacity:.7; }
.ch-title { font-family:'Lora',serif; font-weight:500; font-size:.95rem; line-height:1.3; }
.ch-title.dark { color:#2F4153; } .ch-title.light { color:#2F4153; }
.ch-sub { font-family:'Lora',serif; font-size:.72rem; line-height:1.4; }
.ch-sub.dark { color:#587D8E; } .ch-sub.light { color:#2F4153; opacity:.65; }
.ch-pill { display:inline-block; font-family:'Lora',serif; font-style:italic; font-size:.62rem; padding:4px 13px; border-radius:50px; width:fit-content; }
.ch-pill.dark  { border:1px solid #587D8E; color:#587D8E; }
.ch-pill.light { border:1px solid #2F4153; color:#2F4153; opacity:.7; }

.card-sm .ch-info  { padding:12px 14px; gap:5px; }
.card-sm .ch-tag   { font-size:.5rem; letter-spacing:.14em; }
.card-sm .ch-title { font-size:.75rem; line-height:1.25; }
.card-sm .ch-sub   { font-size:.6rem; line-height:1.3; }
.card-sm .ch-pill  { font-size:.52rem; padding:3px 9px; }

/* ── MODAL ── */
.modal-overlay { display:none; position:fixed; inset:0; z-index:1000; align-items:center; justify-content:center; padding:24px; }
.modal-overlay.active { display:flex; }
.modal-blur { position:absolute; inset:0; backdrop-filter:blur(14px); background:rgba(47,65,83,.55); }
.card-scene { position:relative; z-index:2; width:clamp(320px,62vw,820px); aspect-ratio:16/9; }
.card-flipper { width:100%; height:100%; animation:flipIn .6s cubic-bezier(.23,1,.32,1) forwards; border-radius:clamp(10px,1.2vw,18px); box-shadow:0 32px 80px rgba(0,0,0,.55); overflow:hidden; }
@keyframes flipIn { 0%{transform:rotateY(-90deg) scale(.88);opacity:0} 65%{transform:rotateY(5deg) scale(1.01);opacity:1} 100%{transform:rotateY(0) scale(1);opacity:1} }

.flip-back { width:100%; height:100%; display:flex; flex-direction:row; align-items:center; gap:clamp(20px,4vw,60px); padding:clamp(24px,4vw,48px) clamp(28px,5vw,60px); }
.back-left  { flex:1; display:flex; flex-direction:column; justify-content:center; }
.back-right { flex:1; display:flex; flex-direction:column; justify-content:center; gap:clamp(14px,1.8vw,24px); }
.modal-label { font-family:'Lora',serif; font-size:clamp(.65rem,.78vw,.78rem); letter-spacing:.12em; text-transform:uppercase; }
.modal-title { font-family:'Alice',serif; font-size:clamp(1.2rem,2vw,1.9rem); line-height:1.25; margin-top:clamp(8px,1vw,14px); }
.modal-desc  { font-size:clamp(.78rem,.95vw,.95rem); line-height:1.75; margin-top:clamp(10px,1.2vw,16px); }
.modal-tags  { display:flex; flex-wrap:wrap; gap:clamp(6px,.8vw,10px); }
.modal-tag   { padding:clamp(4px,.4vw,6px) clamp(10px,1.2vw,16px); border-radius:20px; font-size:clamp(.65rem,.75vw,.78rem); letter-spacing:.04em; }
.modal-cta   { display:inline-flex; align-items:center; gap:10px; font-family:'Lora',serif; font-size:clamp(.78rem,.9vw,.92rem); text-decoration:none; border-bottom:1px solid; padding-bottom:3px; width:fit-content; transition:opacity .3s; cursor:none; }
.modal-cta::after { content:'→'; transition:transform .3s; }
.modal-cta:hover { opacity:.75; }
.modal-cta:hover::after { transform:translateX(4px); }

.scheme-teal { background:var(--steel-blue); }
.scheme-teal .modal-label { color:var(--light-blue); }
.scheme-teal .modal-title { color:var(--beige); }
.scheme-teal .modal-desc  { color:var(--light-blue); }
.scheme-teal .modal-tag   { border:1px solid rgba(167,193,209,.4); color:var(--beige); }
.scheme-teal .modal-cta   { color:var(--beige); border-color:rgba(221,216,212,.35); }

.scheme-blue { background:var(--light-blue); }
.scheme-blue .modal-label { color:var(--dark-blue); }
.scheme-blue .modal-title { color:var(--dark-blue); }
.scheme-blue .modal-desc  { color:var(--dark-blue); }
.scheme-blue .modal-tag   { border:1px solid rgba(47,65,83,.4); color:var(--dark-blue); }
.scheme-blue .modal-cta   { color:var(--dark-blue); border-color:rgba(47,65,83,.35); }

.modal-close { position:absolute; top:clamp(10px,1.5vw,18px); right:clamp(10px,1.5vw,18px); width:32px; height:32px; background:rgba(47,65,83,.7); border:.5px solid rgba(221,216,212,.25); border-radius:50%; color:#DDD8D4; font-size:.8rem; display:flex; align-items:center; justify-content:center; cursor:pointer; z-index:10; transition:background .2s; }
.modal-close:hover { background:rgba(47,65,83,.95); }

@media(max-width:768px){
    .card-scene { width:88vw; aspect-ratio:3/4; }
    .flip-back { flex-direction:column; padding:clamp(20px,5vw,32px); gap:clamp(16px,4vw,24px); overflow-y:auto; }
    .card-sm { width:200px; height:150px; } .card-lg { width:290px; height:200px; }
}

/* ── FOOTER ── */
.contact { padding:clamp(60px,8vh,100px) clamp(20px,3.5vw,60px); background:var(--dark-blue); text-align:center; border-top:1px solid rgba(167,193,209,.15); }
.contact h2 { font-family:'Alice',serif; font-size:clamp(2rem,4.5vw,4rem); color:var(--beige); margin-bottom:clamp(24px,3vw,40px); }
.contact-email { font-family:'Lora',serif; font-size:clamp(.95rem,1.2vw,1.3rem); color:var(--light-blue); text-decoration:none; border-bottom:1px solid var(--light-blue); padding-bottom:clamp(2px,.3vw,4px); transition:color .3s; cursor:none; }
.contact-email:hover { color:var(--white); }
.social-links { margin-top:clamp(24px,3vw,40px); display:flex; justify-content:center; gap:clamp(16px,2.5vw,30px); flex-wrap:wrap; }
.social-links a { font-family:'Lora',serif; font-size:clamp(.8rem,.85vw,.9rem); color:var(--steel-blue); text-decoration:none; transition:color .3s; cursor:none; }
.social-links a:hover { color:var(--white); }
.footer-bottom { margin-top:clamp(36px,5vh,60px); padding-top:clamp(18px,2.5vh,30px); border-top:1px solid rgba(255,255,255,.1); display:flex; justify-content:space-between; flex-wrap:wrap; gap:10px; max-width:1200px; margin-left:auto; margin-right:auto; }
.footer-bottom p { font-family:'Lora',serif; font-size:clamp(.7rem,.78vw,.8rem); color:var(--steel-blue); }
</style>
