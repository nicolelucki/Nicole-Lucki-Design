const cursor = document.getElementById('cursor');
const ring   = document.getElementById('cursorRing');
let mx=0, my=0, rx=0, ry=0, menuIsOpen=false;

function setCursorTheme(t) {
    cursor.className = 'cursor ' + t;
    ring.className   = 'cursor-ring ' + t;
}

document.addEventListener('mousemove', e => {
    mx = e.clientX; my = e.clientY;
    cursor.style.left = mx+'px'; cursor.style.top = my+'px';
    if (menuIsOpen) { setCursorTheme('menu'); return; }
    const hdr = document.getElementById('header').getBoundingClientRect();
    if (e.clientY <= hdr.bottom) { setCursorTheme('dark'); return; }
    const el = document.elementFromPoint(e.clientX, e.clientY);
    if (el) {
        const card = el.closest('.card');
        if (card) {
            const bg = window.getComputedStyle(card).backgroundColor;
            setCursorTheme(bg === 'rgb(47, 65, 83)' ? 'light' : 'dark');
            return;
        }
    }
    setCursorTheme('light');
});

(function animateRing(){
    rx += (mx-rx)*.12; ry += (my-ry)*.12;
    ring.style.left = rx+'px'; ring.style.top = ry+'px';
    requestAnimationFrame(animateRing);
})();

document.addEventListener('mouseover', e => {
    if (e.target.closest('a,button,.menu-btn,.lang-toggle,.card'))
        ring.style.cssText += 'width:56px;height:56px;';
});
document.addEventListener('mouseout', e => {
    if (e.target.closest('a,button,.menu-btn,.lang-toggle,.card'))
        ring.style.cssText += 'width:36px;height:36px;';
});

// ── MENÚ ──
