    const ov  = document.getElementById('menuOverlay');
    const hdr = document.getElementById('header');
    btn.classList.toggle('active');
    ov.classList.toggle('active');
    menuIsOpen = ov.classList.contains('active');
    document.body.style.overflow = menuIsOpen ? 'hidden' : '';
    hdr.style.background      = menuIsOpen ? 'transparent' : 'rgba(221,216,212,0.95)';
    hdr.style.backdropFilter  = menuIsOpen ? 'none' : 'blur(10px)';
    setCursorTheme(menuIsOpen ? 'menu' : 'dark');
}

